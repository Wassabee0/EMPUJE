# Public Supabase values. Use the new publishable key when your project has one.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server-only key for admin route handlers/server actions. Do not prefix with NEXT_PUBLIC.
SUPABASE_SECRET_KEY=sb_secret_your_key

# Used in magic-link redirects and Vercel production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Temporary local-only admin preview while Supabase is not configured.
# Disabled automatically in production and ignored once Supabase server config exists.
DEV_ADMIN_ACCESS_CODE=local
